# --- Telegram ---
# From: https://my.telegram.org/apps (create an app)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+12025551234          # international format

# --- Notion ---
# Integration token from: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxx
# Database IDs from the URL: notion.so/<workspace>/<THIS_PART>?v=...
NOTION_CONTACTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_INTERACTIONS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Sync behavior ---
SYNC_DAYS_BACK=1                     # how many days of history per sync run
SYNC_MAX_MESSAGES_PER_CHAT=50        # max messages to pull per dialog
