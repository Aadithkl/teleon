# ── Telegram (required) ───────────────────────────────────────────────────────
# From: https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+12025551234

# ── AI provider (optional) ────────────────────────────────────────────────────
# Options: claude | gemini | openai | none
# If none or unset: NLP enrichment still runs, AI summary is skipped
AI_PROVIDER=none

# Override default model for the selected provider (optional)
# AI_MODEL=claude-sonnet-4-6

# Single key slot — used by whichever provider is active
# AI_API_KEY=

# Or use provider-specific keys:
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# ── Notion (optional) ─────────────────────────────────────────────────────────
# All three must be set for Notion writes to be enabled
# Integration token: https://www.notion.so/my-integrations
NOTION_TOKEN=
# Database IDs from URL: notion.so/<workspace>/<THIS_PART>?v=...
NOTION_CONTACTS_DB_ID=
NOTION_INTERACTIONS_DB_ID=
NOTION_FOLLOWUPS_DB_ID=

# Data source IDs — needed for notion-client v3 queries (data_sources.query)
# Different from the DB IDs above. Find via: share a DB view → copy link → UUID in URL
# Or run: teleon setup  (auto-fills these for you)
NOTION_CONTACTS_DS_ID=
NOTION_INTERACTIONS_DS_ID=
NOTION_FOLLOWUPS_DS_ID=

# ── Sync behaviour ────────────────────────────────────────────────────────────
SYNC_DAYS_BACK=1
SYNC_MAX_MESSAGES_PER_CHAT=50
SYNC_DMS_ONLY=false
AUTO_TRACK_NEW_CHATS=false
